---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import RecipeCard from "../components/RecipeCard";

const allRecipes = await getCollection("recipe");
const recentRecipes = allRecipes
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6)
  .map((r) => ({ id: r.id, title: r.data.title, href: `/recipes/${r.id}/`, category: r.data.category }));
---

<BaseLayout pageTitle="Recetario">
  <Header />
  <main id="main-content" class="max-w-6xl mx-auto px-4 py-12">
    <section class="text-center mb-12" aria-labelledby="welcome-title">
      <h1 id="welcome-title" class="text-3xl font-bold tracking-widest text-[var(--color-charcoal)] uppercase">
        Bienvenido/a
      </h1>
      <p class="text-[var(--color-olive)] mt-2 font-medium">Últimas recetas añadidas</p>
    </section>

    <section class="bg-[var(--color-cream)] rounded-2xl p-8" aria-label="Recetas recientes">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentRecipes.map((recipe) => (
          <li>
            <RecipeCard client:visible title={recipe.title} href={recipe.href} category={recipe.category} />
          </li>
        ))}
      </ul>
    </section>
  </main>
</BaseLayout>